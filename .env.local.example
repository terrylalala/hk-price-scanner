# Copy to .env.local and fill in. NEVER commit .env.local.

# --- Required ---
# Google Gemini API key. Used for both photo identification and grounded search.
GEMINI_API_KEY=

# --- Optional: cross-device sync ---
# Neon Postgres connection string. Without it the app stores scans in
# localStorage only (per-device).
DATABASE_URL=

# --- Optional: photo storage ---
# Vercel Blob. On Vercel, OIDC provides BLOB_STORE_ID automatically and no
# static token is needed. Locally, use a read-write token.
# Without either, the app still works — it just doesn't keep the photos.
BLOB_READ_WRITE_TOKEN=

# --- Optional: model overrides ---
# GEMINI_MODEL is the grounded PRICE search model. Defaults to the
# `gemini-flash-latest` alias, which always resolves to the current Flash model.
GEMINI_MODEL=
# GEMINI_VISION_MODEL is the identification model. Defaults to
# `gemini-flash-lite-latest` — identification is pure extraction and Lite is ~10x
# faster than full Flash for the same result. Override if Lite misreads products.
GEMINI_VISION_MODEL=

# --- Optional: daily AI caps ---
# Grounded search is billed per search query, so these matter.
DAILY_IDENTIFY_LIMIT=40
DAILY_PRICES_LIMIT=40
DAILY_ADVICE_LIMIT=20

# --- Multi-user (NOT used in v1) ---
# Setting all three switches the app from single-user to accounts. Leave blank
# for now; see lib/session.ts.
# AUTH_SECRET=
# AUTH_GOOGLE_ID=
# AUTH_GOOGLE_SECRET=
# APP_PASSWORD=
